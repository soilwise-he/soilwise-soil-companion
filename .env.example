# =============================================================================
# SoilWise Soil Companion — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Only OPENAI_API_KEY is strictly required to run the chatbot with OpenAI.
# All other variables have sensible defaults in application.conf.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider (required: one of the two sections below)
# -----------------------------------------------------------------------------

# Provider selection: "openai" (default) or "ollama"
# LLM_PROVIDER=openai

# --- OpenAI (default) ---
OPENAI_API_KEY=your-openai-api-key-here

# --- Ollama (local models) ---
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_TIMEOUT=60000

# -----------------------------------------------------------------------------
# Core application
# -----------------------------------------------------------------------------

# SOIL_COMPANION_HOST=localhost
# SOIL_COMPANION_PORT=8080
# SOIL_COMPANION_VERSION=0.1.0-SNAPSHOT

# Session expiration in minutes (-1 to disable)
# SESSION_EXPIRATION_MINUTES=15

# Safety limits
# UPLOAD_MAX_CHARS=200000
# CHAT_MAX_SEQUENTIAL_TOOLS=10
# CHAT_MAX_PROMPT_CHARS=800000

# -----------------------------------------------------------------------------
# Demo authentication
# -----------------------------------------------------------------------------

# DEMO_USERNAME=demo@soilwise
# DEMO_PASSWORD=demo1234
# DEMO_DISPLAY_NAME=SoilWise User

# -----------------------------------------------------------------------------
# Data directories
# -----------------------------------------------------------------------------

# KNOWLEDGE_DIR=./data/knowledge/
# FEEDBACK_LOG_DIR=./data/feedback-logs/
# FEEDBACK_LOG_PREFIX=feedback

# -----------------------------------------------------------------------------
# SoilWise Catalog / Solr (required for catalog search)
# -----------------------------------------------------------------------------

# SOLR_BASE_URL=https://solr.soilwise-he.containers.wur.nl/solr/records/select
# SOLR_USERNAME=your-solr-username
# SOLR_PASSWORD=your-solr-password
# CATALOG_TIMEOUT_MS=15000

# -----------------------------------------------------------------------------
# AgroDataCube — NL agricultural field data (optional)
# -----------------------------------------------------------------------------

# AGRODATACUBE_BASE_URL=https://agrodatacube.wur.nl/api/v2/rest
# AGRODATACUBE_ACCESS_TOKEN=your-agrodatacube-token
# AGRODATACUBE_TIMEOUT_MS=15000

# -----------------------------------------------------------------------------
# OpenAgroKPI — NL field-level KPIs (optional)
# -----------------------------------------------------------------------------

# OPENAGRO_BASE_URL=https://openagrokpi.wur.nl/api/v1
# OPENAGRO_ACCESS_TOKEN=your-openagrokpi-api-key
# OPENAGRO_TIMEOUT_MS=15000

# -----------------------------------------------------------------------------
# ISRIC SoilGrids (optional, public API — no credentials needed)
# -----------------------------------------------------------------------------

# SOILGRIDS_BASE_URL=https://rest.isric.org/soilgrids/v2.0
# SOILGRIDS_QUERY_ENDPOINT=/properties/query

# -----------------------------------------------------------------------------
# Debug logging
# -----------------------------------------------------------------------------

# DEBUG_LOG_FINAL_AI_RESPONSE=false
# AI_FINAL_LOG_PREFIX=[AI_FINAL]
